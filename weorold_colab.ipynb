   "source": [
    "# 🌍 Weorold: GPU-Accelerated Procedural Planet Generation\n",
    "\n",
    "Welcome to the Colab-optimized version of **Weorold**. This notebook leverages NVIDIA GPUs to simulate complex geological processes like hydraulic erosion and tectonic uplift in seconds rather than minutes.\n",
    "\n",
    "### 🚀 Setup\n",
    "Run the cell below to install dependencies and verify GPU acceleration."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title Install Dependencies & Verify GPU\n",
    "!pip install cupy-cuda12x opencv-python-headless\n",
    "!apt-get install -y ffmpeg\n",
    "\n",
    "import cupy as cp\n",
    "import cv2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from IPython.display import Image, Video, display\n",
    "\n",
    "print(f\"\\n✅ GPU Verified: {cp.cuda.Device(0).attributes['MultiProcessorCount']} Multiprocessors detected.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 🛠️ Interactive Pipeline\n",
    "Adjust the parameters below to customize your world. The pipeline will:\n",
    "1. Fractalize a sketch or random noise into a coastline.\n",
    "2. Synthesize a base heightmap.\n",
    "3. Apply **Tectonic Uplift**.\n",
    "4. Simulate **1,000,000+ Particles** of Hydraulic Erosion on the GPU.\n",
    "5. Generate Biomes and Hydrology.\n",
    "6. Render a high-fidelity 3D rotating globe."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title Generate Your Planet { run: \"auto\" }\n",
    "planet_name = \"aethelgard\" # @param {type:\"string\"}\n",
    "erosion_particles = 1000000 # @param {type:\"slider\", min:100000, max:5000000, step:100000}\n",
    "tectonic_influence = 0.4 # @param {type:\"slider\", min:0.0, max:1.0, step:0.05}\n",
    "temperature = 0.5 # @param {type:\"slider\", min:0.0, max:1.0, step:0.1}\n",
    "moisture = 0.6 # @param {type:\"slider\", min:0.0, max:1.0, step:0.1}\n",
    "render_frames = 60 # @param {type:\"slider\", min:30, max:120, step:10}\n",
    "\n",
    "import wp1_fractal_coastline as wp1\n",
    "import wp2_heightmap_synthesis as wp2\n",
    "import wp3_biome_texturing as wp3\n",
    "import wp4_cloud_layer as wp4\n",
    "import wp5_final_renderer as wp5\n",
    "import wp9_tectonics as wp9\n",
    "import wp10_hydrology as wp10\n",
    "import wp11_erosion_gpu as wp11_gpu\n",
    "import weorold_ultra as globe\n",
    "\n",
    "def run_colab_pipeline():\n",
    "    # 1. Base Coastline\n",
    "    print(\"[1/8] Generating coastline...\")\n",
    "    # Using a random noise start if no sketch provided\n",
    "    wp1.process_sketch_to_fractal_mask(None, upscale_factor=4, noise_strength=20.0)\n",
    "    \n",
    "    # 2. Heightmap\n",
    "    print(\"[2/8] Synthesizing heightmap...\")\n",
    "    wp2.synthesize_heightmap('wp1_fractal_mask.png')\n",
    "    \n",
    "    # 3. Tectonics\n",
    "    print(\"[3/8] Applying tectonics...\")\n",
    "    base_h16 = cv2.imread('wp2_height_map.png', cv2.IMREAD_UNCHANGED)\n",
    "    tectonic_h16 = wp9.apply_tectonics_to_heightmap(base_h16, tectonic_influence=tectonic_influence)\n",
    "    \n",
    "    # 4. GPU Erosion\n",
    "    print(f\"[4/8] Simulating {erosion_particles} particles on GPU...\")\n",
    "    eroded_h16 = wp11_gpu.simulate_hydraulic_erosion_gpu(tectonic_h16, num_particles=erosion_particles)\n",
    "    cv2.imwrite(f'{planet_name}_height_map.png', eroded_h16)\n",
    "    \n",
    "    # 5. Hydrology\n",
    "    print(\"[5/8] Calculating hydrology...\")\n",
    "    river_map, lake_map = wp10.simulate_hydrology(eroded_h16, mask_path='wp1_fractal_mask.png')\n",
    "    \n",
    "    # 6. Biomes\n",
    "    print(\"[6/8] Generating surface texture...\")\n",
    "    wp3.create_surface_texture(f'{planet_name}_height_map.png', \n",
    "                               temperature=temperature, \n",
    "                               moisture=moisture, \n",
    "                               output_prefix=f'{planet_name}_wp3')\n",
    "    \n",
    "    texture = cv2.imread(f'{planet_name}_wp3_surface_texture.png')\n",
    "    texture_rgb = cv2.cvtColor(texture, cv2.COLOR_BGR2RGB)\n",
    "    hydrology_texture = wp10.apply_hydrology_to_texture(texture_rgb, river_map, lake_map)\n",
    "    cv2.imwrite(f'{planet_name}_final_texture.png', cv2.cvtColor(hydrology_texture, cv2.COLOR_RGB2BGR))\n",
    "    \n",
    "    # 7. Rendering\n",
    "    print(\"[7/8] Rendering final 2D maps...\")\n",
    "    wp4.create_cloud_layer(eroded_h16.shape)\n",
    "    wp5.render_final_maps(\n",
    "        texture_path=f'{planet_name}_final_texture.png',\n",
    "        heightmap_path=f'{planet_name}_height_map.png',\n",
    "        cloud_path='wp4_cloud_map.png',\n",
    "        mask_path='wp1_fractal_mask.png',\n",
    "        output_prefix=f'{planet_name}_wp5'\n",
    "    )\n",
    "    \n",
    "    # 8. 3D Globe Animation\n",
    "    print(f\"[8/8] Creating 3D Globe ({render_frames} frames)...\")\n",
    "    output_video = f'{planet_name}_orbit.mp4'\n",
    "    globe.create_rotating_globe(\n",
    "        f'{planet_name}_wp5_shaded_clouds.png', \n",
    "        output_video, \n",
    "        frames=render_frames, \n",
    "        fps=30\n",
    "    )\n",
    "    \n",
    "    display(Video(output_video, embed=True, width=600))\n",
    "    print(\"\\n✨ Planet Generation Complete!\")\n",
    "\n",
    "run_colab_pipeline()"
   ]
  }\n",
 ],
